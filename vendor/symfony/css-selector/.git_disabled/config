[core]
	repositoryformatversion = 0
	filemode = false
	bare = false
	logallrefupdates = true
	symlinks = false
	ignorecase = true
[remote "origin"]
	url = https://github.com/symfony/css-selector.git
	fetch = +refs/heads/*:refs/remotes/origin/*
	pushurl = git@github.com:symfony/css-selector.git
[branch "7.3"]
	remote = origin
	merge = refs/heads/7.3
[remote "composer"]
	url = https://github.com/symfony/css-selector.git
	fetch = +refs/heads/*:refs/remotes/composer/*
