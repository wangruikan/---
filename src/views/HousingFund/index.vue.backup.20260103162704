        <el-form-item label="公司缴纳比例" prop="company_ratio">
          <el-input-number
            v-model="configForm.company_ratio"
            :min="0"
            :max="1"
            :precision="4"
            :step="0.0001"
            placeholder="请输入公司缴纳比例"
            style="width: 100%"
          />
          <div class="form-tip">例如：0.12 表示 12%</div>
        </el-form-item>
        <el-form-item label="设为默认">
          <el-switch v-model="configForm.is_default" />
          <div class="form-tip">设为默认后，该地区将使用此配置作为默认配置</div>
        </el-form-item>
      </el-form>
      <template #footer>
        <el-button @click="showCreateConfigDialog = false">取消</el-button>
        <el-button type="primary" @click="saveConfig" :loading="saving">
          {{ editingConfig ? '更新' : '创建' }}
        </el-button>
      </template>
    </el-dialog>

    <!-- 添加表头字段对话框 -->
