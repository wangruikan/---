
.container.data-v-04caa8b0 {
	min-height: 100vh;
	background: #F5F7FA;
}
.filter-tabs.data-v-04caa8b0 {
	display: flex;
	background: #fff;
	padding: 20rpx;
}
.tab-item.data-v-04caa8b0 {
	flex: 1;
	text-align: center;
	padding: 20rpx 0;
	font-size: 28rpx;
	color: #666;
	border-bottom: 4rpx solid transparent;
}
.tab-active.data-v-04caa8b0 {
	color: #667eea;
	font-weight: bold;
	border-bottom-color: #667eea;
}
.contract-list.data-v-04caa8b0 {
	padding: 20rpx;
}
.contract-item.data-v-04caa8b0 {
	background: #fff;
	border-radius: 16rpx;
	padding: 30rpx;
	margin-bottom: 20rpx;
}
.contract-header.data-v-04caa8b0 {
	display: flex;
	justify-content: space-between;
	align-items: center;
	margin-bottom: 24rpx;
}
.contract-type.data-v-04caa8b0 {
	display: flex;
	align-items: center;
}
.type-icon.data-v-04caa8b0 {
	font-size: 40rpx;
	margin-right: 12rpx;
}
.type-text.data-v-04caa8b0 {
	font-size: 32rpx;
	font-weight: bold;
	color: #333;
}
.status-tag.data-v-04caa8b0 {
	padding: 8rpx 20rpx;
	border-radius: 40rpx;
	font-size: 24rpx;
}
.status-pending.data-v-04caa8b0 {
	background: #FFF3E0;
	color: #FF9800;
}
.status-signed.data-v-04caa8b0 {
	background: #E3F2FD;
	color: #2196F3;
}
.status-completed.data-v-04caa8b0 {
	background: #E8F5E9;
	color: #4CAF50;
}
.status-rejected.data-v-04caa8b0 {
	background: #FFEBEE;
	color: #F44336;
}
.contract-info.data-v-04caa8b0 {
	margin-bottom: 20rpx;
}
.info-text.data-v-04caa8b0 {
	display: block;
	font-size: 26rpx;
	color: #666;
	line-height: 40rpx;
}
.contract-action.data-v-04caa8b0 {
	text-align: right;
}
.action-btn.data-v-04caa8b0 {
	color: #667eea;
	font-size: 28rpx;
	font-weight: bold;
}
.empty-state.data-v-04caa8b0 {
	text-align: center;
	padding: 200rpx 0;
}
.empty-icon.data-v-04caa8b0 {
	display: block;
	font-size: 120rpx;
	margin-bottom: 30rpx;
}
.empty-text.data-v-04caa8b0 {
	font-size: 28rpx;
	color: #999;
}

/* 须知弹窗样式 */
.notice-modal.data-v-04caa8b0 {
	position: fixed;
	top: 0;
	left: 0;
	right: 0;
	bottom: 0;
	z-index: 9999;
}
.modal-mask.data-v-04caa8b0 {
	position: absolute;
	top: 0;
	left: 0;
	right: 0;
	bottom: 0;
	background: rgba(0, 0, 0, 0.6);
}
.modal-content.data-v-04caa8b0 {
	position: absolute;
	top: 50%;
	left: 50%;
	transform: translate(-50%, -50%);
	width: 85%;
	max-width: 600rpx;
	background: #fff;
	border-radius: 20rpx;
	overflow: hidden;
}
.modal-header.data-v-04caa8b0 {
	display: flex;
	justify-content: space-between;
	align-items: center;
	padding: 30rpx;
	border-bottom: 1px solid #eee;
}
.modal-title.data-v-04caa8b0 {
	font-size: 36rpx;
	font-weight: bold;
	color: #333;
}
.close-btn.data-v-04caa8b0 {
	width: 50rpx;
	height: 50rpx;
	line-height: 45rpx;
	text-align: center;
	font-size: 50rpx;
	color: #999;
}
.modal-body.data-v-04caa8b0 {
	padding: 30rpx;
}
.notice-text.data-v-04caa8b0 {
	font-size: 28rpx;
	color: #666;
	margin-bottom: 20rpx;
	line-height: 1.6;
}
.notice-file.data-v-04caa8b0 {
	display: flex;
	align-items: center;
	padding: 20rpx;
	background: #f5f7fa;
	border-radius: 10rpx;
	margin-bottom: 20rpx;
}
.file-icon.data-v-04caa8b0 {
	font-size: 40rpx;
	margin-right: 15rpx;
}
.file-name.data-v-04caa8b0 {
	flex: 1;
	font-size: 28rpx;
	color: #333;
}
.read-btn.data-v-04caa8b0 {
	width: 100%;
	height: 80rpx;
	line-height: 80rpx;
	background: linear-gradient(to right, #667eea, #764ba2);
	color: #fff;
	border-radius: 10rpx;
	font-size: 28rpx;
	margin-bottom: 30rpx;
	border: none;
	padding: 0;
}
.read-btn.data-v-04caa8b0::after {
	border: none;
}
.agree-section.data-v-04caa8b0 {
	padding: 20rpx 0;
}
.agree-label.data-v-04caa8b0 {
	display: flex;
	align-items: center;
	font-size: 28rpx;
	color: #333;
}
.agree-label checkbox.data-v-04caa8b0 {
	margin-right: 15rpx;
	transform: scale(1.2);
}
.modal-footer.data-v-04caa8b0 {
	display: flex;
	border-top: 1px solid #eee;
}
.cancel-btn.data-v-04caa8b0,
.confirm-btn.data-v-04caa8b0 {
	flex: 1;
	height: 90rpx;
	line-height: 90rpx;
	text-align: center;
	font-size: 32rpx;
	border: none;
	border-radius: 0;
	margin: 0;
	padding: 0;
}
.cancel-btn.data-v-04caa8b0 {
	background: #fff;
	color: #666;
	border-right: 1px solid #eee;
}
.confirm-btn.data-v-04caa8b0 {
	background: linear-gradient(to right, #667eea, #764ba2);
	color: #fff;
}
.confirm-btn[disabled].data-v-04caa8b0 {
	background: #ccc;
	color: #999;
}
.confirm-btn.data-v-04caa8b0::after,
.cancel-btn.data-v-04caa8b0::after {
	border: none;
}
