<view class="document-upload-page data-v-17eb5e5a"><view class="header data-v-17eb5e5a"><view class="title data-v-17eb5e5a">资料上传</view><view class="subtitle data-v-17eb5e5a">请按要求上传以下资料（每个资料可上传多个文件）</view></view><view class="stats-card data-v-17eb5e5a"><view class="stat-item data-v-17eb5e5a"><text class="stat-value data-v-17eb5e5a">{{a}}</text><text class="stat-label data-v-17eb5e5a">总资料数</text></view><view class="stat-divider data-v-17eb5e5a"></view><view class="stat-item data-v-17eb5e5a"><text class="stat-value uploaded data-v-17eb5e5a">{{b}}</text><text class="stat-label data-v-17eb5e5a">已上传</text></view><view class="stat-divider data-v-17eb5e5a"></view><view class="stat-item data-v-17eb5e5a"><text class="stat-value pending data-v-17eb5e5a">{{c}}</text><text class="stat-label data-v-17eb5e5a">待上传</text></view></view><view class="document-list data-v-17eb5e5a"><view wx:for="{{d}}" wx:for-item="item" wx:key="j" class="{{['document-item', 'data-v-17eb5e5a', item.k && 'uploaded']}}"><view class="item-header data-v-17eb5e5a"><view class="item-title data-v-17eb5e5a"><text class="title-text data-v-17eb5e5a">{{item.a}}</text><view class="tags data-v-17eb5e5a"><text wx:if="{{item.b}}" class="tag required data-v-17eb5e5a">必填</text><text wx:else class="tag optional data-v-17eb5e5a">选填</text><text class="tag type data-v-17eb5e5a">{{item.c}}</text></view></view><text class="{{['status', 'data-v-17eb5e5a', item.e]}}">{{item.d}}</text></view><view wx:if="{{item.f}}" class="files-list data-v-17eb5e5a"><view wx:for="{{item.g}}" wx:for-item="file" wx:key="d" class="file-item data-v-17eb5e5a"><view class="file-info data-v-17eb5e5a"><text class="file-name data-v-17eb5e5a">{{file.a}}</text><text class="file-size data-v-17eb5e5a">{{file.b}}</text></view><view class="file-actions data-v-17eb5e5a"><button class="action-btn delete data-v-17eb5e5a" bindtap="{{file.c}}"><text class="icon data-v-17eb5e5a">🗑</text></button></view></view></view><view class="upload-action data-v-17eb5e5a"><butt