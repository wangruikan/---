
.document-upload-page.data-v-17eb5e5a {
	min-height: 100vh;
	background-color: #f5f5f5;
	padding-bottom: 40rpx;
}
.header.data-v-17eb5e5a {
	background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
	padding: 60rpx 30rpx 40rpx;
	color: white;
}
.title.data-v-17eb5e5a {
	font-size: 48rpx;
	font-weight: bold;
	margin-bottom: 10rpx;
}
.subtitle.data-v-17eb5e5a {
	font-size: 26rpx;
	opacity: 0.9;
}

/* 统计卡片 */
.stats-card.data-v-17eb5e5a {
	margin: -40rpx 30rpx 30rpx;
	background-color: white;
	border-radius: 16rpx;
	padding: 40rpx 20rpx;
	display: flex;
	justify-content: space-around;
	align-items: center;
	box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}
.stat-item.data-v-17eb5e5a {
	display: flex;
	flex-direction: column;
	align-items: center;
	flex: 1;
}
.stat-value.data-v-17eb5e5a {
	font-size: 52rpx;
	font-weight: bold;
	color: #667eea;
	margin-bottom: 10rpx;
}
.stat-value.uploaded.data-v-17eb5e5a { color: #67c23a;
}
.stat-value.pending.data-v-17eb5e5a { color: #e6a23c;
}
.stat-label.data-v-17eb5e5a {
	font-size: 24rpx;
	color: #909399;
}
.stat-divider.data-v-17eb5e5a {
	width: 2rpx;
	height: 60rpx;
	background-color: #e4e7ed;
}

/* 资料列表 */
.document-list.data-v-17eb5e5a {
	padding: 0 30rpx;
}
.document-item.data-v-17eb5e5a {
	background-color: white;
	border-radius: 16rpx;
	padding: 30rpx;
	margin-bottom: 20rpx;
	box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}
.document-item.uploaded.data-v-17eb5e5a {
	border-left: 6rpx solid #67c23a;
}
.item-header.data-v-17eb5e5a {
	display: flex;
	justify-content: space-between;
	align-items: flex-start;
	margin-bottom: 20rpx;
}
.item-title.data-v-17eb5e5a { flex: 1;
}
.title-text.data-v-17eb5e5a {
	font-size: 32rpx;
	font-weight: 500;
	color: #303133;
	display: block;
	margin-bottom: 10rpx;
}
.tags.data-v-17eb5e5a {
	display: flex;
	gap: 10rpx;
	flex-wrap: wrap;
}
.tag.data-v-17eb5e5a {
	display: inline-block;
	padding: 4rpx 12rpx;
	border-radius: 6rpx;
	font-size: 22rpx;
	color: white;
}
.tag.required.data-v-17eb5e5a { background-color: #f56c6c;
}
.tag.optional.data-v-17eb5e5a { background-color: #909399;
}
.tag.type.data-v-17eb5e5a { background-color: #409eff;
}
.status.data-v-17eb5e5a {
	font-size: 26rpx;
	font-weight: 500;
	white-space: nowrap;
}
.status.uploaded.data-v-17eb5e5a { color: #67c23a;
}
.status.pending.data-v-17eb5e5a { color: #e6a23c;
}

/* 文件列表 */
.files-list.data-v-17eb5e5a {
	margin-bottom: 20rpx;
}
.file-item.data-v-17eb5e5a {
	display: flex;
	align-items: center;
	justify-content: space-between;
	padding: 16rpx 20rpx;
	background-color: #f0f9ff;
	border-radius: 12rpx;
	margin-bottom: 12rpx;
}
.file-info.data-v-17eb5e5a {
	flex: 1;
	min-width: 0;
}
.file-name.data-v-17eb5e5a {
	font-size: 26rpx;
	color: #303133;
	display: block;
	overflow: hidden;
	text-overflow: ellipsis;
	white-space: nowrap;
}
.file-size.data-v-17eb5e5a {
	font-size: 22rpx;
	color: #909399;
}
.file-actions.data-v-17eb5e5a {
	display: flex;
	gap: 10rpx;
}
.action-btn.data-v-17eb5e5a {
	width: 60rpx;
	height: 60rpx;
	padding: 0;
	margin: 0;
	border: none;
	border-radius: 8rpx;
	display: flex;
	align-items: center;
	justify-content: center;
	background-color: transparent;
}
.action-btn.delete.data-v-17eb5e5a { background-color: #fff1f0;
}
.action-btn .icon.data-v-17eb5e5a { font-size: 28rpx;
}

/* 上传按钮 */
.upload-action.data-v-17eb5e5a {
	padding: 10rpx 0;
}
.upload-btn.data-v-17eb5e5a {
	width: 100%;
	display: flex;
	align-items: center;
	justify-content: center;
	gap: 10rpx;
	padding: 24rpx;
	border-radius: 12rpx;
	background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
	color: white;
	font-size: 28rpx;
	font-weight: 500;
	border: none;
	box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.4);
}
.upload-btn .icon.data-v-17eb5e5a {
	font-size: 32rpx;
}

/* 空状态 */
.empty-state.data-v-17eb5e5a {
	display: flex;
	flex-direction: column;
	align-items: center;
	justify-content: center;
	padding: 120rpx 30rpx;
}
.empty-icon.data-v-17eb5e5a {
	font-size: 120rpx;
	margin-bottom: 30rpx;
}
.empty-text.data-v-17eb5e5a {
	font-size: 32rpx;
	color: #909399;
	margin-bottom: 10rpx;
}
.empty-hint.data-v-17eb5e5a {
	font-size: 26rpx;
	color: #c0c4cc;
}

/* 加载中 */
.loading.data-v-17eb5e5a {
	text-align: center;
	padding: 100rpx 0;
	color: #909399;
}
