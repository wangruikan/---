
.container.data-v-ca6eb76f {
	padding: 20rpx;
	background-color: #f5f5f5;
	min-height: 100vh;
	padding-bottom: 120rpx;
}
.form-section.data-v-ca6eb76f {
	background-color: #fff;
	margin-bottom: 20rpx;
	padding: 30rpx;
	border-radius: 10rpx;
}
.section-title.data-v-ca6eb76f {
	font-size: 32rpx;
	font-weight: bold;
	margin-bottom: 30rpx;
	color: #333;
	display: flex;
	justify-content: space-between;
	align-items: center;
	position: relative;
}
.fill-sample-btn.data-v-ca6eb76f {
	display: flex;
	align-items: center;
	padding: 8rpx 16rpx;
	background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
	border-radius: 20rpx;
	color: #fff;
	font-size: 22rpx;
	box-shadow: 0 2rpx 8rpx rgba(102, 126, 234, 0.3);
	transition: all 0.3s;
}
.fill-sample-btn.data-v-ca6eb76f:active {
	transform: scale(0.95);
	box-shadow: 0 1rpx 4rpx rgba(102, 126, 234, 0.3);
}
.fill-sample-btn .icon.data-v-ca6eb76f {
	font-size: 24rpx;
	margin-right: 6rpx;
}
.fill-sample-btn .text.data-v-ca6eb76f {
	font-weight: 500;
}
.add-btn.data-v-ca6eb76f {
	font-size: 28rpx;
	color: #007AFF;
	font-weight: normal;
}
.form-item.data-v-ca6eb76f {
	margin-bottom: 30rpx;
	display: flex;
	align-items: center;
}
.label.data-v-ca6eb76f {
	width: 200rpx;
	font-size: 28rpx;
	color: #666;
	flex-shrink: 0;
}
.form-item input.data-v-ca6eb76f,
.form-item textarea.data-v-ca6eb76f,
.picker.data-v-ca6eb76f {
	flex: 1;
	font-size: 28rpx;
	color: #333;
	min-height: 60rpx;
	line-height: 60rpx;
}
.form-item textarea.data-v-ca6eb76f {
	min-height: 120rpx;
	line-height: 1.5;
	padding: 10rpx;
	border: 1rpx solid #ddd;
	border-radius: 5rpx;
}
.textarea.data-v-ca6eb76f {
	width: 100%;
	min-height: 120rpx;
	line-height: 1.5;
	padding: 10rpx;
	border: 1rpx solid #ddd;
	border-radius: 5rpx;
	font-size: 28rpx;
}
.picker.data-v-ca6eb76f {
	border: 1rpx solid #ddd;
	border-radius: 5rpx;
	padding: 0 20rpx;
}
.radio-label.data-v-ca6eb76f {
	margin-right: 30rpx;
	font-size: 28rpx;
}
.list-item.data-v-ca6eb76f {
	background-color: #f9f9f9;
	padding: 20rpx;
	margin-bottom: 20rpx;
	border-radius: 10rpx;
}
.item-header.data-v-ca6eb76f {
	display: flex;
	justify-content: space-between;
	align-items: center;
	margin-bottom: 20rpx;
	font-size: 28rpx;
	color: #666;
}
.delete-btn.data-v-ca6eb76f {
	color: #f56c6c;
	font-size: 26rpx;
}
.submit-section.data-v-ca6eb76f {
	position: fixed;
	bottom: 0;
	left: 0;
	right: 0;
	padding: 20rpx;
	background-color: #fff;
	box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.1);
}
.submit-section button.data-v-ca6eb76f {
	width: 100%;
	height: 88rpx;
	line-height: 88rpx;
	font-size: 32rpx;
	border-radius: 8rpx;
}

/* 签名相关样式 */
.declaration-box.data-v-ca6eb76f {
	padding: 30rpx;
	background: #fff9e6;
	border-left: 6rpx solid #ff9800;
	border-radius: 8rpx;
	margin-bottom: 30rpx;
}
.declaration-text.data-v-ca6eb76f {
	font-size: 28rpx;
	line-height: 1.8;
	color: #333;
}
.signature-wrapper.data-v-ca6eb76f {
	margin-top: 30rpx;
}
.signature-wrapper .label.data-v-ca6eb76f {
	display: block;
	font-size: 28rpx;
	font-weight: bold;
	margin-bottom: 20rpx;
	color: #333;
}
.signature-canvas-box.data-v-ca6eb76f {
	background: #fff;
	border: 2rpx dashed #ccc;
	border-radius: 10rpx;
	padding: 20rpx;
}
.signature-canvas.data-v-ca6eb76f {
	background: #fafafa;
	border-radius: 8rpx;
	display: block;
}
.canvas-tips.data-v-ca6eb76f {
	text-align: center;
	font-size: 24rpx;
	color: #999;
	margin-top: 10rpx;
	padding: 10rpx;
}

/* 按钮组 */
.signature-buttons.data-v-ca6eb76f {
	display: flex;
	gap: 20rpx;
	margin-top: 20rpx;
}
.clear-signature-btn.data-v-ca6eb76f {
	flex: 1;
	height: 70rpx;
	line-height: 70rpx;
	background: #ff5722;
	color: #fff;
	border: none;
	border-radius: 8rpx;
	font-size: 28rpx;
}
.save-signature-btn.data-v-ca6eb76f {
	flex: 1;
	height: 70rpx;
	line-height: 70rpx;
	background: #4CAF50;
	color: #fff;
	border: none;
	border-radius: 8rpx;
	font-size: 28rpx;
}

/* 签名预览 */
.signature-preview-box.data-v-ca6eb76f {
	background: #fff;
	border: 2rpx solid #4CAF50;
	border-radius: 10rpx;
	padding: 20rpx;
}
.signature-image.data-v-ca6eb76f {
	width: 100%;
	min-height: 200rpx;
	max-height: 400rpx;
	border-radius: 8rpx;
	display: block;
}

/* 必填标记 */
.label.required.data-v-ca6eb76f::after {
	content: '*';
	color: #f56c6c;
	margin-left: 4rpx;
}

/* 禁用的picker */
.picker.disabled.data-v-ca6eb76f {
	color: #999;
	background-color: #f5f5f5;
}

/* 一寸照片上传 */
.photo-item.data-v-ca6eb76f {
	align-items: flex-start;
}
.photo-upload.data-v-ca6eb76f {
	width: 200rpx;
	height: 260rpx;
	border: 2rpx dashed #ccc;
	border-radius: 8rpx;
	display: flex;
	flex-direction: column;
	align-items: center;
	justify-content: center;
	background-color: #fafafa;
	overflow: hidden;
}
.photo-preview.data-v-ca6eb76f {
	width: 100%;
	height: 100%;
}
.photo-placeholder.data-v-ca6eb76f {
	display: flex;
	flex-direction: column;
	align-items: center;
	justify-content: center;
}
.photo-icon.data-v-ca6eb76f {
	font-size: 60rpx;
	margin-bottom: 10rpx;
}
.photo-text.data-v-ca6eb76f {
	font-size: 24rpx;
	color: #999;
}
